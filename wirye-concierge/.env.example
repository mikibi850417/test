# App
APP_ENV=development
APP_NAME=wirye-militopia-kiosk
APP_PORT_WEB=3000
APP_PORT_API=8000
APP_PUBLIC_BASE_URL=https://kiosk.example.com
APP_API_BASE_URL=https://kiosk.example.com/api

# Database
POSTGRES_DB=wirye_kiosk
POSTGRES_USER=wirye_app
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://wirye_app:change_me@postgres:5432/wirye_kiosk

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET=change_me_super_long_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ADMIN_COOKIE_NAME=wirye_admin_session
ADMIN_BOOTSTRAP_EMAIL=admin@wirye.local
ADMIN_BOOTSTRAP_PASSWORD=change_me_admin

# Next.js
NEXT_PUBLIC_DEFAULT_HOTEL_ID=HOTEL_WIRYE_MILITOPIA_001
NEXT_PUBLIC_DEFAULT_LANG=ko
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_KIOSK_IDLE_HOME_SECONDS=90
NEXT_PUBLIC_KIOSK_CACHE_TTL_SECONDS=300

# LLM Concierge (Gemini)
CONCIERGE_LLM_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
CONCIERGE_LLM_TIMEOUT_MS=8000
CONCIERGE_INBOX_STORE_PATH=

# Snapshot / uploads
SNAPSHOT_DIR=/app/data/snapshots
UPLOAD_DIR=/app/data/uploads
MEDIA_BASE_URL=/media

# Import / publish
IMPORT_TMP_DIR=/app/data/imports
DEFAULT_PUBLISH_NOTE=initial publish
ALLOW_PUBLISH_WITH_OPEN_CONFLICTS=false

# Device
DEVICE_TOKEN_ENABLED=false
HEARTBEAT_ENABLED=true
HEARTBEAT_STALE_MINUTES=15

# Logging
LOG_LEVEL=INFO
JSON_LOGS=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://kiosk.example.com

# NGINX / TLS (documented, may be handled outside container)
NGINX_SERVER_NAME=kiosk.example.com
TLS_EMAIL=ops@example.com
